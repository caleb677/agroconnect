# ══════════════════════════════════════════════════════════════════
#  AgroConnect Backend — Environment Variables
#  STEP 1: Copy this file:  cp .env.example .env
#  STEP 2: Fill in each value below
# ══════════════════════════════════════════════════════════════════

# ── SERVER ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── DATABASE (Supabase PostgreSQL) ────────────────────────────────
# Get from: https://supabase.com
#   → Your Project → Settings (gear icon) → Database → URI tab
#   → Replace [YOUR-PASSWORD] with the password you set
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# ── JWT SECRET ────────────────────────────────────────────────────
# Make up any long random string (min 32 characters)
JWT_SECRET=agroconnect-muranga-2025-replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── ADMIN ACCOUNT ─────────────────────────────────────────────────
ADMIN_EMAIL=calebmwasi22@gmail.com

# ── ANTHROPIC AI (Claude Crop Advisor) ────────────────────────────
# Get from: https://console.anthropic.com → API Keys → Create key
# Cost: ~KES 300-500/month for moderate use
ANTHROPIC_API_KEY=sk-ant-api03-PUT-YOUR-KEY-HERE

# ── M-PESA DARAJA (Safaricom STK Push) ────────────────────────────
# Get from: https://developer.safaricom.co.ke → Create App
# Use "sandbox" for testing, "production" when going live
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=PUT-YOUR-CONSUMER-KEY-HERE
MPESA_CONSUMER_SECRET=PUT-YOUR-CONSUMER-SECRET-HERE
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Sandbox passkey above works for testing. Replace with real one when going live.
# Your callback URL (update after deploying backend online):
MPESA_CALLBACK_URL=http://localhost:4000/api/mpesa/callback

# ── EMAIL NOTIFICATIONS (Resend) ──────────────────────────────────
# Get from: https://resend.com → API Keys
# Free plan: 3,000 emails/month
RESEND_API_KEY=re_PUT-YOUR-RESEND-KEY-HERE
EMAIL_FROM=noreply@agroconnect.co.ke

# ── FILE UPLOADS (Cloudinary) ─────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
# Free plan: 25GB storage
CLOUDINARY_CLOUD_NAME=PUT-YOUR-CLOUD-NAME
CLOUDINARY_API_KEY=PUT-YOUR-CLOUDINARY-KEY
CLOUDINARY_API_SECRET=PUT-YOUR-CLOUDINARY-SECRET
