# ══════════════════════════════════════════════════════════════════
#  AgroConnect Frontend — Environment Variables
#  STEP 1: Copy this file:  cp .env.example .env
#  STEP 2: Fill in each value below
# ══════════════════════════════════════════════════════════════════

# ── Backend API URL ───────────────────────────────────────────────
# While developing locally (backend running on port 4000):
VITE_API_URL=http://localhost:4000/api

# After deploying backend to Render.com, change to:
# VITE_API_URL=https://agroconnect-api.onrender.com/api
